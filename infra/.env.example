# ============================================================
# Variables de entorno de la infraestructura Devsu
# Copia este archivo a ".env" y ajusta los valores si lo necesitas:
#     cp .env.example .env       (Linux/Mac)
#     copy .env.example .env     (Windows)
# NOTA: .env está en .gitignore — nunca subir secretos reales al repo.
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=devsu
POSTGRES_USER=devsu
POSTGRES_PASSWORD=devsu
POSTGRES_PORT=5432

# ---------- RabbitMQ ----------
RABBITMQ_USER=devsu
RABBITMQ_PASSWORD=devsu
RABBITMQ_VHOST=devsu
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---------- Keycloak ----------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8081

# ---------- Vault ----------
VAULT_ROOT_TOKEN=devsu-root-token
VAULT_PORT=8200
