# ============================================================
# .gitignore — Proyecto Devsu .NET (monorepo)
# ============================================================

# ---------- Build .NET ----------
# Nota: NO usar el patron amplio "[Oo]ut/" porque colisiona con la carpeta
# hexagonal "Port/Out". El output de build queda cubierto por bin/obj/publish.
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Dd]ebugPublic/
[Rr]eleases/
x64/
x86/
artifacts/
publish/
*.dll
*.exe
*.pdb

# ---------- Restore / NuGet ----------
*.nupkg
*.snupkg
.packages/
packages/
project.lock.json
project.fragment.lock.json

# ---------- Test / cobertura ----------
[Tt]est[Rr]esults/
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info

# ---------- IDE / editores ----------
.vs/
.vscode/
.idea/
.claude/
*.user
*.suo
*.userprefs
*.DotSettings.user

# ---------- Secretos y entornos ----------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
appsettings.*.local.json
secrets.json

# ---------- Sistema operativo / temporales ----------
.DS_Store
Thumbs.db
*.log
*.tmp
*.bak
*~
