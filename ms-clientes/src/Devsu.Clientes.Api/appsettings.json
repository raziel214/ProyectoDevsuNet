{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8085"
      }
    }
  },
  "Database": {
    "Host": "localhost",
    "Port": "5432",
    "Name": "devsu_clientes"
  },
  "MigrateOnStartup": true,
  "Vault": {
    "Enabled": true,
    "Address": "http://localhost:8200",
    "MountPoint": "secret",
    "SecretPath": "ms-clientes",
    "Username": "devsu-reader"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "devsu",
    "Exchange": "devsu.clientes.exchange"
  },
  "Keycloak": {
    "Authority": "http://localhost:8081/realms/internos-dev",
    "RequireHttpsMetadata": false
  }
}
