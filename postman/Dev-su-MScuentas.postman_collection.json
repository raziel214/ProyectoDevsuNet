{
  "info": {
    "name": "Dev-su-MScuentas",
    "description": "Microservicio de Cuentas y Movimientos (F1-F4). Ejecuta 'Obtener Token' primero; el JWT se guarda en {{token}} y se usa en todas las peticiones (auth heredada). Completa la variable 'clientSecret' antes de empezar. Requiere que los clientes existan (corre antes la colección Dev-su-MSclients).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8086" },
    { "key": "keycloakUrl", "value": "http://localhost:8081" },
    { "key": "realm", "value": "internos-dev" },
    { "key": "clientId", "value": "ms-clientes" },
    { "key": "clientSecret", "value": "<COMPLETAR: Keycloak > Clients > ms-clientes > Credentials>" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "0. Obtener Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('token', json.access_token);",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('access_token recibido', () => pm.expect(json.access_token).to.be.a('string'));"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "client_credentials" },
            { "key": "client_id", "value": "{{clientId}}" },
            { "key": "client_secret", "value": "{{clientSecret}}" }
          ]
        },
        "url": {
          "raw": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token",
          "host": ["{{keycloakUrl}}"],
          "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
        },
        "description": "Obtiene un JWT (client_credentials) y lo guarda en la variable {{token}}."
      }
    },
    {
      "name": "Cuentas (F1)",
      "item": [
